{
  "name": "timeproofs-protocol",
  "version": "0.1.0-alpha.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "timeproofs-protocol",
      "version": "0.1.0-alpha.0",
      "license": "Apache-2.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "node_modules/@timeproofs/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@timeproofs/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@timeproofs/stripe-connector": {
      "resolved": "packages/stripe-connector",
      "link": true
    },
    "node_modules/@timeproofs/verdict-engine": {
      "resolved": "packages/verdict-engine",
      "link": true
    },
    "packages/cli": {
      "name": "@timeproofs/cli",
      "version": "0.1.0-alpha.0",
      "license": "Apache-2.0",
      "bin": {
        "timeproofs": "bin/timeproofs.mjs"
      }
    },
    "packages/core": {
      "name": "@timeproofs/core",
      "version": "0.1.0-alpha.0",
      "license": "Apache-2.0"
    },
    "packages/stripe-connector": {
      "name": "@timeproofs/stripe-connector",
      "version": "0.1.0-alpha.0",
      "license": "Apache-2.0"
    },
    "packages/verdict-engine": {
      "name": "@timeproofs/verdict-engine",
      "version": "0.1.0-alpha.0",
      "license": "Apache-2.0"
    }
  }
}
